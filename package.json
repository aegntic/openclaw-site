    "react-dom": "latest"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "typescript": "latest",
    "wrangler": "latest"
  }
}
